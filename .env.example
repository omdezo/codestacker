# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/flowcare"

# Server
PORT=3000
NODE_ENV=development

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Admin Defaults (used for initial seed)
ADMIN_EMAIL=admin@flowcare.com
ADMIN_PASSWORD=Admin@1234

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_BOOKINGS=5
